# Copy this to .env and fill in your values

# Ollama (default — runs locally, no API key needed)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# Embedding model (runs locally via sentence-transformers, no API needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: set to "docker" to use a running Qdrant container instead of in-memory
QDRANT_MODE=memory
QDRANT_HOST=localhost
QDRANT_PORT=6333
